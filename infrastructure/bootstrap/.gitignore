# Terraform state - contains cluster PKI secrets, treat like secret.yaml
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
states/**

# Terraform working directory
.terraform/

# Actual variable values (IPs, credentials)
terraform.tfvars

# Shared secrets
shared/secrets.auto.tfvars

# Vault initialization output - contains unseal keys and root token
# CRITICAL: Back this up securely! Required to unseal Vault after restarts.
secrets/
vault-init.json

# Downloaded PVE CA certificates - these are node-specific and should not be committed
# Import these into your browser trust store after running terraform apply
pve-ca-*.pem

.env
