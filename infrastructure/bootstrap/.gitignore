# Terraform state - contains cluster PKI secrets, treat like secret.yaml
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directory
.terraform/

# Actual variable values (IPs, credentials)
terraform.tfvars

# Generated credential outputs
kubeconfig.yaml
talosconfig.yaml

# Vault initialization output - contains unseal keys and root token
# CRITICAL: Back this up securely! Required to unseal Vault after restarts.
vault-init.json
