# ============================================================
# Proxmox Configuration
# ============================================================

# The HTTPS endpoint for your Proxmox server (must match proxmox_node_name below)
proxmox_endpoint = "https://<PROXMOX_IP>:8006"

# Proxmox authentication credentials
proxmox_username = "root@pam"
proxmox_password = "<YOUR_PROXMOX_PASSWORD>"
proxmox_insecure = true  # Set to false if using valid SSL certificates

# Name of the Proxmox node to use for SSH operations
# This must match the 'pve_node' field of one of your nodes below
proxmox_node_name = "server-01"

# ============================================================
# Talos Cluster Configuration
# ============================================================

# Virtual IP for the Kubernetes API - must be in the same subnet as your nodes,
# outside your DHCP range, and not assigned to any physical machine
talos_cluster_vip = "<VIRTUAL_IP>"

# ============================================================
# Node Configuration
# ============================================================
# One entry per physical machine. The map key IS the Kubernetes node hostname -
# keep these stable across rebuilds to avoid Longhorn disk UUID mismatches.
#
# IMPORTANT: vm_id must be unique across your entire Proxmox datacentre
# ip_address should be reserved/static in your DHCP server or router
# proxmox_ip is the IP of the Proxmox server hosting this VM

nodes = {
  "controlplane-worker-1" = {
    vm_id        = 100
    pve_node     = "server-01"
    proxmox_ip   = "<PROXMOX_1_IP>"
    cpu_cores    = 4
    memory_mb    = 16384  # Adjust based on your hardware
    disk_gb      = 100    # Adjust based on your storage
    ip_address   = "<NODE_1_IP>"
    mac_address  = "<MAC_ADDRESS_1>"  # Generate with: printf "BC:24:11:%02X:%02X:%02X\n" $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256))
  }
  "controlplane-worker-2" = {
    vm_id        = 101
    pve_node     = "server-02"
    proxmox_ip   = "<PROXMOX_2_IP>"
    cpu_cores    = 4
    memory_mb    = 16384
    disk_gb      = 100
    ip_address   = "<NODE_2_IP>"
    mac_address  = "<MAC_ADDRESS_2>"
  }
}

# ============================================================
# External Secrets (Required)
# ============================================================
# These credentials are required for external integrations.
#
# To obtain these credentials:
# - Cloudflare: See networking/cloudflared/README.md
# - Renovate: See ci-cd/renovate/README.md

# Cloudflare tunnel token (base64 encoded string from Cloudflare dashboard)
cloudflare_tunnel_token = "<YOUR_CLOUDFLARE_TUNNEL_TOKEN>"

# GitHub App private key for Renovate - base64 encode your downloaded .pem file:
#   cat /path/to/private-key.pem | base64 -w0
github_app_private_key = "<BASE64_ENCODED_GITHUB_APP_PRIVATE_KEY>"
