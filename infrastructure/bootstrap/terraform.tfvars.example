# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored - do not commit it.
#
# Proxmox credentials are NOT set here - they go in environment variables:
#
#   export PROXMOX_VE_ENDPOINT="https://192.168.1.10:8006"
#   export PROXMOX_VE_INSECURE="true"
#   export PROXMOX_VE_USERNAME="root@pam"
#   export PROXMOX_VE_PASSWORD="your-proxmox-password"

# ============================================================
# Proxmox
# ============================================================

# Name of the Proxmox node to use for SSH by Terraform.
# This must match the 'pve_node' field of one of your nodes below.
# Terraform will look up the IP from that node's 'proxmox_ip' field.
proxmox_node_name = "server-01"

# Datastore for the Talos ISO (must support 'iso' content type - 'local' usually works)
proxmox_iso_datastore = "local"

# Datastore for VM disks (e.g. 'local-lvm', 'local-zfs')
proxmox_disk_datastore = "local-lvm"

# ============================================================
# Talos / Cluster
# ============================================================

talos_version = "v1.12.4"
cluster_name  = "talos-homelab"

# Virtual IP - must be in the same subnet as nodes
cluster_vip = "192.168.1.100"

# ============================================================
# Nodes
# ============================================================
# One entry per physical machine. The map key IS the Kubernetes node hostname -
# keep these stable across rebuilds to avoid Longhorn diskUUID mismatches.
#
# vm_id must be unique across your entire Proxmox node.
# ip_address should be reserved/static in your DHCP server or router.
# proxmox_ip is the IP of the Proxmox server hosting this VM (used for DNS and SSH).

nodes = {
  "controlplane-worker-1" = {
    vm_id       = 100
    pve_node    = "server-01"
    proxmox_ip  = "192.168.1.XXX"  # Replace with actual Proxmox server 1 IP
    cpu_cores   = 4
    memory_mb   = 16384
    disk_gb     = 100
    ip_address  = "192.168.1.101"
    mac_address = "BC:24:11:00:00:01" # Must match your router's static DHCP lease for this IP
  }
  "controlplane-worker-2" = {
    vm_id       = 101
    pve_node    = "server-02"
    proxmox_ip  = "192.168.1.XXX"  # Replace with actual Proxmox server 2 IP
    cpu_cores   = 4
    memory_mb   = 16384
    disk_gb     = 100
    ip_address  = "192.168.1.102"
    mac_address = "BC:24:11:00:00:02" # Must match your router's static DHCP lease for this IP
  }
}

# ============================================================
# External Secrets (Required Environment Variables)
# ============================================================
# These secrets are NOT set in this file - they must be provided
# via environment variables before running terraform apply:
#
#   export TF_VAR_cloudflare_tunnel_token="your-token-here"
#   export TF_VAR_github_app_private_key="$(cat /path/to/private-key.pem)"
#
# To obtain these credentials:
# - Cloudflare: See networking/cloudflared/README.md
# - Renovate: See ci-cd/renovate/README.md
