{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "dependencyDashboard": true,
    "automerge": false,
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "argocd": {
        "managerFilePatterns": [
            "/ci-cd/argocd/.*/.*\\.ya?ml$/"
        ]
    },
    "kubernetes": {
        "managerFilePatterns": [
            "/.*\\.yaml$/",
            "/.*\\.yml$/"
        ],
        "ignorePaths": [
            "infrastructure/",
            "**/docker-compose*.yaml"
        ]
    },
    "terraform": {},
    "nix": {
        "enabled": true
    },
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update Kustomize remote resource URLs",
            "managerFilePatterns": [
                "/.*/kustomization\\.yaml$/"
            ],
            "matchStrings": [
                "-\\s+https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>[^/]+)/.*"
            ],
            "datasourceTemplate": "github-tags",
            "versioningTemplate": "semver"
        },
        {
            "customType": "regex",
            "description": "Update CloudNativePG PostgreSQL images",
            "managerFilePatterns": [
                "/storage/cloudnative-pg/.*\\.yaml$/"
            ],
            "matchStrings": [
                "imageName:\\s+(?<depName>[^:]+):(?<currentValue>[^\\s]+)"
            ],
            "datasourceTemplate": "docker",
            "versioningTemplate": "semver"
        }
    ],
    "packageRules": [
        {
            "description": "Label major updates for manual review",
            "matchUpdateTypes": [
                "major"
            ],
            "labels": [
                "dependencies",
                "major-update"
            ]
        },
        {
            "description": "Ignore private Harbor image tags until registry credentials are configured",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "harbor.okwilkins.dev/**"
            ],
            "enabled": false
        },
        {
            "description": "Force docker datasource for OCI Helm charts (ghcr.io)",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "ghcr.io/grafana/helm-charts/grafana-operator"
            ],
            "enabled": true
        }
    ]
}
