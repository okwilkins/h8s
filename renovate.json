{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "dependencyDashboard": true,
    "automerge": false,
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "argocd": {},
    "kubernetes": {},
    "terraform": {},
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update OCI Helm charts in ArgoCD Applications (ghcr.io)",
            "managerFilePatterns": [
                "/ci-cd/argocd/.*\\.ya?ml$/"
            ],
            "matchStrings": [
                "repoURL:\\s*ghcr\\.io\\/(?<registryPath>[^\\s]+)\\s*\\n\\s*chart:\\s*(?<chartName>[^\\s]+)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>[^\\s]+)"
            ],
            "datasourceTemplate": "docker",
            "depNameTemplate": "ghcr.io/{{{registryPath}}}/{{{chartName}}}",
            "versioningTemplate": "semver"
        }
    ],
    "packageRules": [
        {
            "description": "Label major updates for manual review",
            "matchUpdateTypes": [
                "major"
            ],
            "labels": [
                "dependencies",
                "major-update"
            ]
        },
        {
            "description": "Ignore private Harbor image tags until registry credentials are configured",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "harbor.okwilkins.dev/**"
            ],
            "enabled": false
        },
        {
            "description": "Force docker datasource for OCI Helm charts (ghcr.io)",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "ghcr.io/grafana/helm-charts/grafana-operator"
            ],
            "enabled": true
        }
    ]
}
