{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "dependencyDashboard": true,
    "automerge": false,
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "argocd": {
        "managerFilePatterns": [
            "/ci-cd/argocd/.*/.*\\.ya?ml$/"
        ]
    },
    "kubernetes": {
        "managerFilePatterns": [
            "/.*\\.yaml$/",
            "/.*\\.yml$/"
        ],
        "ignorePaths": [
            "infrastructure/",
            "**/docker-compose*.yaml"
        ]
    },
    "terraform": {},
    "nix": {
        "enabled": true
    },
    "customManagers": [
        {
          "customType": "regex",
          "description": "Update official Docker Hub cached images in Harbor (non-community images)",
          "managerFilePatterns": [
              "/.*\\.yaml$"
          ],
          "matchStrings": [
              "image:\\s+harbor\\.okwilkins\\.dev/docker-hub-cache/(?<depName>[^/\\s:]+):(?<currentValue>[^\\s]+)"
          ],
          "datasourceTemplate": "docker",
          "depNameTemplate": "library/{{depName}}"
        },
        {
          "customType": "regex",
          "description": "Update community Docker Hub cached images in Harbor (non-community images)",
          "managerFilePatterns": [
              "/.*\\.yaml$"
          ],
          "matchStrings": [
              "image:\\s+harbor\\.okwilkins\\.dev/docker-hub-cache/(?<depName>[^/\\s]+/[^\\s:]+):(?<currentValue>[^\\s]+)"
          ],
          "datasourceTemplate": "docker"
        }{
            "customType": "regex",
            "description": "Update GHCR cached images in Harbor",
            "managerFilePatterns": [
                "/.*\\.yaml$/"
            ],
            "matchStrings": [
                "image:\\s+harbor\\.okwilkins\\.dev/ghcr-cache/(?<depName>[^\\s:]+):(?<currentValue>[^\\s]+)"
            ],
            "datasourceTemplate": "docker",
            "depNameTemplate": "ghcr.io/{{depName}}"
        },
        {
            "customType": "regex",
            "description": "Update Kustomize remote resource URLs",
            "managerFilePatterns": [
                "/.*/kustomization\\.yaml$/"
            ],
            "matchStrings": [
                "-\\s+https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>[^/]+)/.*"
            ],
            "datasourceTemplate": "github-tags",
            "versioningTemplate": "semver"
        },
        {
            "customType": "regex",
            "description": "Update CloudNativePG PostgreSQL images",
            "managerFilePatterns": [
                "/storage/cloudnative-pg/.*\\.yaml$/"
            ],
            "matchStrings": [
                "imageName:\\s+(?<depName>[^\\s]+):(?<currentValue>[^\\s]+)"
            ],
            "datasourceTemplate": "docker",
            "versioningTemplate": "loose"
        }
    ],
    "packageRules": [
        {
            "description": "Label major updates for manual review",
            "matchUpdateTypes": [
                "major"
            ],
            "labels": [
                "dependencies",
                "major-update"
            ]
        },
        {
            "description": "Enable CloudNativePG images from ghcr.io",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "ghcr.io/cloudnative-pg/**"
            ],
            "enabled": true
        },
        {
            "description": "Force docker datasource for OCI Helm charts (ghcr.io)",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "ghcr.io/grafana/helm-charts/grafana-operator"
            ],
            "enabled": true
        }
    ]
}
